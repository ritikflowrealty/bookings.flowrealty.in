# Admin password (server-side only, never exposed to client)
ADMIN_PASSWORD=FlowRealty2026!

# Database (libSQL / SQLite-compatible)
# - Local dev:    leave blank to use file:./data/flow-realty.db
# - Production:   point at a Turso database
#                 https://turso.tech > create db > copy the libsql:// URL and auth token
DATABASE_URL=
DATABASE_AUTH_TOKEN=

# Local file path used only when DATABASE_URL is empty
DATABASE_PATH=./data/flow-realty.db

# Public site URL (used in metadata, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://booking.flowrealty.in

# Optional global Razorpay fallback. Per-project keys (in admin panel) always override.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
